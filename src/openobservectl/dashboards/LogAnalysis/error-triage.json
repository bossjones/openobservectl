{
  "version": 5,
  "dashboardId": "error-triage",
  "title": "Error Triage",
  "description": "What is erroring right now and what does it say (full-text match_all).",
  "role": "",
  "owner": "centralized_monitoring",
  "variables": { "list": [], "showDynamicFilters": false },
  "tabs": [
    {
      "tabId": "default",
      "name": "Default",
      "panels": [
        {
          "id": "panel_errors_over_time",
          "type": "line",
          "title": "Errors over time by stream",
          "description": "Rows matching 'error', per stream.",
          "config": { "show_legends": true, "unit": null, "decimals": 0 },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT histogram(_timestamp) AS \"x_axis_1\", count(*) AS \"y_axis_1\" FROM \"host_logs\" WHERE match_all('error') GROUP BY x_axis_1 ORDER BY x_axis_1",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "host_logs",
                "stream_type": "logs",
                "x": [{ "label": "Timestamp", "alias": "x_axis_1", "column": "_timestamp", "aggregationFunction": "histogram", "sortBy": "ASC" }],
                "y": [{ "label": "host_logs", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            },
            {
              "query": "SELECT histogram(_timestamp) AS \"x_axis_1\", count(*) AS \"y_axis_1\" FROM \"container_logs\" WHERE match_all('error') GROUP BY x_axis_1 ORDER BY x_axis_1",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "container_logs",
                "stream_type": "logs",
                "x": [{ "label": "Timestamp", "alias": "x_axis_1", "column": "_timestamp", "aggregationFunction": "histogram", "sortBy": "ASC" }],
                "y": [{ "label": "container_logs", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            },
            {
              "query": "SELECT histogram(_timestamp) AS \"x_axis_1\", count(*) AS \"y_axis_1\" FROM \"k0s_pods\" WHERE match_all('error') GROUP BY x_axis_1 ORDER BY x_axis_1",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "k0s_pods",
                "stream_type": "logs",
                "x": [{ "label": "Timestamp", "alias": "x_axis_1", "column": "_timestamp", "aggregationFunction": "histogram", "sortBy": "ASC" }],
                "y": [{ "label": "k0s_pods", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            }
          ],
          "layout": { "x": 0, "y": 0, "w": 48, "h": 10, "i": 1 }
        },
        {
          "id": "panel_top_error_messages",
          "type": "table",
          "title": "Top error messages (host_logs)",
          "description": "Recurring error lines, grouped by message.",
          "config": { "show_legends": false },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT body AS \"x_axis_1\", count(*) AS \"y_axis_1\" FROM \"host_logs\" WHERE match_all('error') GROUP BY x_axis_1 ORDER BY y_axis_1 DESC LIMIT 20",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "host_logs",
                "stream_type": "logs",
                "x": [{ "label": "message", "alias": "x_axis_1", "column": "body", "aggregationFunction": null }],
                "y": [{ "label": "count", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            }
          ],
          "layout": { "x": 0, "y": 10, "w": 24, "h": 10, "i": 2 }
        },
        {
          "id": "panel_recent_errors",
          "type": "table",
          "title": "Recent errors (host_logs)",
          "description": "Most recent matching error lines.",
          "config": { "show_legends": false },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT _timestamp AS \"x_axis_1\", body AS \"x_axis_2\" FROM \"host_logs\" WHERE match_all('error') ORDER BY _timestamp DESC LIMIT 100",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "host_logs",
                "stream_type": "logs",
                "x": [
                  { "label": "Timestamp", "alias": "x_axis_1", "column": "_timestamp", "aggregationFunction": null },
                  { "label": "message", "alias": "x_axis_2", "column": "body", "aggregationFunction": null }
                ],
                "y": [], "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            }
          ],
          "layout": { "x": 24, "y": 10, "w": 24, "h": 10, "i": 3 }
        }
      ]
    }
  ]
}
