{
  "version": 5,
  "dashboardId": "log-overview",
  "title": "Log Overview",
  "description": "Total log volume and where it comes from, across every ingest stream.",
  "role": "",
  "owner": "centralized_monitoring",
  "variables": { "list": [], "showDynamicFilters": false },
  "tabs": [
    {
      "tabId": "default",
      "name": "Default",
      "panels": [
        {
          "id": "panel_volume_by_stream",
          "type": "line",
          "title": "Log volume by stream",
          "description": "Row count over time, one series per stream.",
          "config": { "show_legends": true, "unit": null, "decimals": 0 },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT histogram(_timestamp) AS \"x_axis_1\", count(*) AS \"y_axis_1\" FROM \"host_logs\" GROUP BY x_axis_1 ORDER BY x_axis_1",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "host_logs",
                "stream_type": "logs",
                "x": [{ "label": "Timestamp", "alias": "x_axis_1", "column": "_timestamp", "aggregationFunction": "histogram", "sortBy": "ASC" }],
                "y": [{ "label": "host_logs", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            },
            {
              "query": "SELECT histogram(_timestamp) AS \"x_axis_1\", count(*) AS \"y_axis_1\" FROM \"container_logs\" GROUP BY x_axis_1 ORDER BY x_axis_1",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "container_logs",
                "stream_type": "logs",
                "x": [{ "label": "Timestamp", "alias": "x_axis_1", "column": "_timestamp", "aggregationFunction": "histogram", "sortBy": "ASC" }],
                "y": [{ "label": "container_logs", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            },
            {
              "query": "SELECT histogram(_timestamp) AS \"x_axis_1\", count(*) AS \"y_axis_1\" FROM \"otlp_logs\" GROUP BY x_axis_1 ORDER BY x_axis_1",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "otlp_logs",
                "stream_type": "logs",
                "x": [{ "label": "Timestamp", "alias": "x_axis_1", "column": "_timestamp", "aggregationFunction": "histogram", "sortBy": "ASC" }],
                "y": [{ "label": "otlp_logs", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            },
            {
              "query": "SELECT histogram(_timestamp) AS \"x_axis_1\", count(*) AS \"y_axis_1\" FROM \"k0s_host\" GROUP BY x_axis_1 ORDER BY x_axis_1",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "k0s_host",
                "stream_type": "logs",
                "x": [{ "label": "Timestamp", "alias": "x_axis_1", "column": "_timestamp", "aggregationFunction": "histogram", "sortBy": "ASC" }],
                "y": [{ "label": "k0s_host", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            },
            {
              "query": "SELECT histogram(_timestamp) AS \"x_axis_1\", count(*) AS \"y_axis_1\" FROM \"k0s_pods\" GROUP BY x_axis_1 ORDER BY x_axis_1",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "k0s_pods",
                "stream_type": "logs",
                "x": [{ "label": "Timestamp", "alias": "x_axis_1", "column": "_timestamp", "aggregationFunction": "histogram", "sortBy": "ASC" }],
                "y": [{ "label": "k0s_pods", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            }
          ],
          "layout": { "x": 0, "y": 0, "w": 48, "h": 10, "i": 1 }
        },
        {
          "id": "panel_total_host",
          "type": "metric",
          "title": "Total host_logs (range)",
          "description": "Row count for the selected time range.",
          "config": { "show_legends": false, "unit": null, "decimals": 0 },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT count(*) AS \"y_axis_1\" FROM \"host_logs\"",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "host_logs",
                "stream_type": "logs",
                "x": [],
                "y": [{ "label": "count", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            }
          ],
          "layout": { "x": 0, "y": 10, "w": 12, "h": 8, "i": 2 }
        },
        {
          "id": "panel_top_container_sources",
          "type": "table",
          "title": "Top container log sources",
          "description": "Noisiest container log files by row count.",
          "config": { "show_legends": false },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT log_file_path AS \"x_axis_1\", count(*) AS \"y_axis_1\" FROM \"container_logs\" GROUP BY x_axis_1 ORDER BY y_axis_1 DESC LIMIT 20",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "container_logs",
                "stream_type": "logs",
                "x": [{ "label": "log_file_path", "alias": "x_axis_1", "column": "log_file_path", "aggregationFunction": null }],
                "y": [{ "label": "count", "alias": "y_axis_1", "column": "_timestamp", "aggregationFunction": "count" }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1 }
            }
          ],
          "layout": { "x": 12, "y": 10, "w": 36, "h": 8, "i": 3 }
        }
      ]
    }
  ]
}
